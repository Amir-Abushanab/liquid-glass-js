{
  "name": "liquidglassjs-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Liquid Glass — the @liquidglassjs packages that power it, plus the showcase.",
  "license": "MIT",
  "author": "Amir Abushanab",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "pnpm --filter showcase dev",
    "play": "pnpm --filter showcase dev",
    "build": "pnpm -r build",
    "build:packages": "pnpm -r --filter \"@liquidglassjs/*\" build",
    "pack:all": "pnpm -r --filter \"@liquidglassjs/*\" exec pnpm pack",
    "release": "pnpm build:packages && changeset publish",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint packages",
    "format": "oxfmt packages",
    "knip": "knip",
    "depcruise": "depcruise packages apps",
    "check": "oxfmt --check packages && oxlint packages && pnpm -r typecheck && knip && depcruise packages apps",
    "changeset": "changeset",
    "ncu": "pnpm dlx npm-check-updates",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "dependency-cruiser": "^18.0.0",
    "knip": "^6.24.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
