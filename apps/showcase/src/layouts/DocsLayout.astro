---
import '@/styles/docs.css';
import { Sidebar } from '@/components/site';
import { BrandMark } from '@/components/brand';
import { AnimatedThemeToggle } from '@/components/theme-toggle';

interface Props {
  title?: string;
  currentSlug?: string;
}
const { title = 'Liquid Glass · Registry', currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL; // '/' in dev, '/liquid-glass-js/' on Pages
const docsHome = base.replace(/\/$/, '') + '/components';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={base + 'favicon.svg'} />
    <script is:inline>
      // Apply the stored theme before paint (no flash). Defaults to the system preference.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches))
            document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="mx-auto flex min-h-screen max-w-7xl flex-col">
      <header
        class="sticky top-0 z-40 flex h-14 items-center gap-2 border-b bg-background/80 px-6 backdrop-blur"
      >
        <a href={docsHome} class="flex items-center gap-2 font-semibold tracking-tight">
          <BrandMark size={26} />
          Liquid Glass
        </a>
        <span class="text-sm text-muted-foreground">registry</span>
        <div class="ml-auto flex items-center gap-2">
          <a href={base} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
            Showcase
          </a>
          <a
            href="https://github.com/amir-abushanab/liquid-glass-js"
            class="text-sm text-muted-foreground transition-colors hover:text-foreground"
          >
            GitHub
          </a>
          <AnimatedThemeToggle client:load />
        </div>
      </header>
      <div class="flex flex-1">
        <aside
          class="sticky top-14 hidden h-[calc(100vh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r px-4 py-6 md:block"
        >
          <Sidebar currentSlug={currentSlug} client:load />
        </aside>
        <main class="min-w-0 flex-1 px-6 py-10 md:px-10">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
