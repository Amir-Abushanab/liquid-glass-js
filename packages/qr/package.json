{
  "name": "@liquidglassjs/qr",
  "version": "0.1.1",
  "description": "Procedural liquid-glass QR code: a WebGL escape hatch built on @liquidglassjs/core.",
  "keywords": [
    "glass",
    "liquid-glass",
    "qr",
    "qrcode",
    "refraction",
    "webgl"
  ],
  "homepage": "https://github.com/amir-abushanab/liquid-glass-js/tree/main/packages/qr#readme",
  "bugs": "https://github.com/amir-abushanab/liquid-glass-js/issues",
  "license": "MIT",
  "author": "Amir Abushanab",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amir-abushanab/liquid-glass-js.git",
    "directory": "packages/qr"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.tsx"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./react": {
        "types": "./dist/react.d.ts",
        "import": "./dist/react.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../../scripts/sync-license.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@liquidglassjs/core": "workspace:^",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "comment:exports": "Dev resolves raw src/*.ts; publishConfig.exports swaps to built dist at publish. Mirrors @liquidglassjs/core."
}
